{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd managed-agent && npm install"
  },
  "deploy": {
    "startCommand": "cd managed-agent && node slack-trigger.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
